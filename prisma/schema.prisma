datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Client {
  id          String   @id @default(cuid())
  companyName String
  email       String   @unique
  domain      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gscConnections  GSCConnection[]
  cmsConnections  CMSConnection[]
  autopilotConfig AutopilotConfig?
  autopilotRuns   AutopilotRun[]
  costLogs        CostLog[]
  reportConfig    ReportConfig?
}

model GSCConnection {
  id                 String    @id @default(cuid())
  clientId           String
  client             Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  siteUrl            String
  serviceAccountJson String
  connectedAt        DateTime  @default(now())
  lastSyncedAt       DateTime?
  syncStatus         String    @default("pending")

  @@unique([clientId, siteUrl])
  @@index([clientId])
}

model CMSConnection {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  cmsType     String
  baseUrl     String
  credentials Json
  testStatus  String   @default("pending")
  connectedAt DateTime @default(now())

  @@unique([clientId, cmsType])
  @@index([clientId])
}

model AutopilotConfig {
  id                String   @id @default(cuid())
  clientId          String   @unique
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enabled           Boolean  @default(false)
  automationScore   String
  maxPagesPerRun    Int      @default(5)
  contentTier       String
  scheduleFrequency String
  dryRunMode        Boolean  @default(true)
  requiresApproval  Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  runs AutopilotRun[]
}

model AutopilotRun {
  id             String          @id @default(cuid())
  clientId       String
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  configId       String
  config         AutopilotConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  status         String
  pagesTargeted  Int
  pagesGenerated Int             @default(0)
  pagesPublished Int             @default(0)
  dryRun         Boolean         @default(false)
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  errorMessage   String?
  results        Json?

  pages   AutopilotPage[]
  costLog CostLog?

  @@index([clientId])
}

model AutopilotPage {
  id               String       @id @default(cuid())
  runId            String
  run              AutopilotRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  pageUrl          String
  gscImpressions   Int
  gscClicks        Int
  gscPosition      Float?
  status           String
  generatedContent Json?
  publishAt        DateTime?
  publishedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime     @default(now())

  @@unique([runId, pageUrl])
  @@index([runId])
  @@index([status, publishAt])
}

model CostLog {
  id             String        @id @default(cuid())
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  runId          String?       @unique
  run            AutopilotRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  service        String
  pagesProcessed Int
  costPerPage    Float
  totalCost      Float
  createdAt      DateTime      @default(now())

  @@index([clientId])
}

model ReportConfig {
  id             String    @id @default(cuid())
  clientId       String    @unique
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recipientEmail String
  ccEmails       String?
  frequency      String    @default("weekly")
  sendDay        Int       @default(1)
  sendHourUTC    Int       @default(9)
  enabled        Boolean   @default(true)
  lastSentAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
model IndexingAccount {
  id              String   @id @default(cuid())
  label           String
  clientEmail     String   @unique
  credentialsJson String
  dailyQuota      Int      @default(200)
  usedToday       Int      @default(0)
  lastResetAt     DateTime @default(now())
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  logs IndexingLog[]
}

model IndexingLog {
  id          String          @id @default(cuid())
  accountId   String
  account     IndexingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  url         String
  type        String          @default("new")
  status      String
  response    String?
  submittedAt DateTime        @default(now())

  @@index([accountId])
  @@index([submittedAt])
}
model IndexingQueue {
  id          String    @id @default(cuid())
  url         String    @unique
  clientId    String
  priority    Int       @default(2)
  status      String    @default("queued")
  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, priority])
  @@index([clientId])
}
model AuditRun {
  id           String    @id @default(cuid())
  clientId     String?
  siteUrl      String
  sitemapUrl   String
  status       String    @default("running")
  totalPages   Int       @default(0)
  sampledPages Int       @default(0)
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  errorMessage String?

  pages    AuditPage[]
  insights AuditInsight[]

  @@index([clientId])
  @@index([startedAt])
}

model AuditPage {
  id                  String   @id @default(cuid())
  runId               String
  run                 AuditRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  url                 String
  statusCode          Int?
  title               String?
  titleLength         Int?
  metaDescription     String?
  metaLength          Int?
  h1Count             Int?
  h1Text              String?
  wordCount           Int?
  internalLinksCount  Int?
  externalLinksCount  Int?
  imageCount          Int?
  imagesMissingAlt    Int?
  canonical           String?
  hasSchema           Boolean  @default(false)
  issues              Json?
  crawledAt           DateTime @default(now())

  @@unique([runId, url])
  @@index([runId])
}

model AuditInsight {
  id          String    @id @default(cuid())
  runId       String
  run         AuditRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  pageUrl     String
  category    String
  priority    Int       @default(2)
  reason      String
  actionTaken String?
  createdAt   DateTime  @default(now())

  @@index([runId, category])
}